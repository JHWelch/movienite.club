<mjml>
  <mj-head>
    <mj-title>Movie Nite Reminder</mj-title>

    <mj-attributes>
      <mj-all font-family="Verdana, sans-serif" background-color="#040404" />

      <mj-text font-size="24px" color="#D5CCCC" line-height="24px"/>
    </mj-attributes>

    <mj-html-attributes>
      <mj-selector path=".list table table">
        <mj-html-attribute name="role">list</mj-html-attribute>
      </mj-selector>

      <mj-selector path=".list table table > tbody">
        <mj-html-attribute name="role">presentation</mj-html-attribute>
      </mj-selector>
    </mj-html-attributes>

    <mj-style>
      a {
        color: #F25785;
      }

      a:hover {
        color: #F4ABBB;
      }

      a:visited {
        color: #F25785;
      }

      .button {

      }
    </mj-style>
  </mj-head>

  <mj-body>
    <mj-section full-width="full-width">
      <mj-column width="100%">
        <mj-text
          padding="0px"
          align="center"
          font-size="16px"
          color="#F25785"
        >Wowell World Studios Presents: Movie Nite Club</mj-text>
      </mj-column>
    </mj-section>

    <mj-section full-width="full-width">
      <mj-column width="100%">
        <mj-text
          align="center"
          font-size="16px"
          line-height="8px"
        >{{date}}</mj-text>

        <mj-text
          align="center"
          font-size="20px"
          font-weight="bold"
          line-height="8px"
        >{{theme}}</mj-text>

        <mj-button
          background-color="#F25785"
          color="#040404"
          font-size="16px"
          font-weight="bold"
          align="center"
          width="120px"
          href="https://movienite.club?rsvp={{eventId}}"
        >RSVP</mj-button>
      </mj-column>
    </mj-section>

    <mj-section full-width="full-width">
      <mj-raw>{{#each movies}}</mj-raw>
        <mj-column width="50%">
          <mj-text
            align="center"
            font-size="30px"
            line-height="30px"
            font-weight="bold"
            color="#F25785"
            padding="5px"
          >{{title}}</mj-text>

          <mj-image
            src="{{posterPath}}"
            alt="{{title}} Poster"
            align="center"
            width="300px"
          />
        </mj-column>
      <mj-raw>{{/each}}</mj-raw>
    </mj-section>

    <mj-section full-width="full-width">
      <mj-column width="500px">
        <mj-raw>{{#each movies}}</mj-raw>
          <mj-text font-size="20px" padding="15px 25px">
            <b>{{time}}</b> - <i>{{title}} ({{year}})</i>
          </mj-text>
        <mj-raw>{{/each}}</mj-raw>

        <mj-button
          padding="30px 0px"
          background-color="#F25785"
          color="#040404"
          font-size="16px"
          font-weight="bold"
          align="center"
          width="120px"
          href="https://movienite.club?rsvp={{eventId}}"
        >RSVP</mj-button>
      </mj-column>
    </mj-section>

    <mj-section full-width="full-width">
      <mj-column width="100%">
        <mj-text
          align="center"
          font-size="10px"
          line-height="8px"
        ><a href="{{unsubscribeUrl}}">unsubscribe</a></mj-text>
      </mj-column>
  </mj-body>
</mjml>
