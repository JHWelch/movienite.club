{
  "name": "movienite.club",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "main": "src/server/main.ts",
  "scripts": {
    "cli": "tsx src/server/cli.ts",
    "lint": "eslint",
    "fix": "npm run lint -- --fix",
    "dev": "concurrently -k -c \"#e7b885,#53ceff\"  \"npm run firebase\" \"sleep 2 && npm run dev:app\" --names=firebase,app",
    "dev:app": "nodemon -w src/server -x tsx src/server/main.ts",
    "firebase": "firebase emulators:start --import emulator-cache",
    "firebase:export": "firebase emulators:export emulator-cache",
    "build": "vite build && npm run build:emails",
    "build:emails": "mkdir -p ./emails/built && mjml --config.minify=true ./emails/*.mjml -o ./emails/built/",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "start": "NODE_ENV=production tsx src/server/main.ts",
    "test": "vitest",
    "test:snapshots": "vitest -u",
    "types": "vue-tsc -p tsconfig.build.json --noEmit",
    "coverage": "vitest run --coverage"
  },
  "keywords": [
    "notion",
    "movies"
  ],
  "author": "Jordan Welch",
  "license": "MIT",
  "dependencies": {
    "@jhwelch/made-with": "^0.0.3",
    "@notionhq/client": "^5.22.0",
    "body-parser": "^2.3.0",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.1.0",
    "ics": "^3.12.0",
    "luxon": "^3.7.2",
    "path": "^0.12.7",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "url": "^0.11.4",
    "vite-express": "^0.22.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@fetch-mock/vitest": "^0.2.18",
    "@heroicons/vue": "^2.2.0",
    "@jhwelch/eslint-config": "^6.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/body-parser": "^1.19.6",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/lodash.debounce": "^4.0.9",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "firebase-tools": "^15.21.0",
    "globals": "^17.6.0",
    "js-confetti": "^0.13.1",
    "jsdom": "^29.1.1",
    "lodash.debounce": "^4.0.8",
    "mjml": "^5.3.0",
    "mockdate": "^3.0.5",
    "nodemon": "^3.1.14",
    "tailwindcss": "^4.3.1",
    "tsc-alias": "^1.8.17",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "vue-tsc": "^3.3.5"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.62.2"
  }
}
